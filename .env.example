# Price Tracker Environment Configuration
# Copy this file to .env and update values

# ===========================================
# Application Settings
# ===========================================
APP_NAME="Price Tracker"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/price-tracker

# ===========================================
# Database Configuration (MariaDB)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=price_tracker
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ===========================================
# Email Configuration (SMTP)
# ===========================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Price Tracker"

# ===========================================
# LINE Messaging API
# ===========================================
# Get these from LINE Developers Console:
# https://developers.line.biz/console/
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ===========================================
# Scraping Configuration
# ===========================================
# User agent for scraping requests
SCRAPER_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Request timeout in seconds
SCRAPER_TIMEOUT=30

# Delay between requests (milliseconds)
SCRAPER_DELAY=1000

# Maximum retries for failed requests
SCRAPER_MAX_RETRIES=3

# ===========================================
# Agent Queue Configuration
# ===========================================
# Maximum jobs to process per agent run
AGENT_MAX_JOBS=10

# Maximum retry attempts for failed jobs
AGENT_MAX_RETRIES=3

# Job lock timeout in seconds
AGENT_LOCK_TIMEOUT=300

# ===========================================
# Alert Configuration
# ===========================================
# Minimum price drop percentage to trigger alert
ALERT_MIN_PRICE_DROP=5

# Cooldown between alerts for same product (hours)
ALERT_COOLDOWN_HOURS=24

# ===========================================
# Matching Configuration
# ===========================================
# Minimum similarity score for auto-matching (0.0 - 1.0)
MATCHING_AUTO_THRESHOLD=0.9

# Minimum score to show as suggestion
MATCHING_SUGGESTION_THRESHOLD=0.6

# ===========================================
# Security
# ===========================================
# Session lifetime in seconds (default: 2 hours)
SESSION_LIFETIME=7200

# CSRF token lifetime in seconds (default: 1 hour)
CSRF_LIFETIME=3600
