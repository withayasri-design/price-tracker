{
    "name": "price-tracker/price-tracker",
    "description": "Multi-platform price tracking system for Thai e-commerce",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.8",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "Agents\\": "agents/",
            "Modules\\": "modules/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "scrape": "php cron/run_agent_queue.php scraper",
        "queue": "php cron/run_agent_queue.php"
    },
    "minimum-stability": "stable"
}
