# Test Environment Configuration
# Copy this to .env.testing and configure for your test environment

# Database (use a separate test database!)
DB_HOST=localhost
DB_NAME=price_tracker_test
DB_USER=root
DB_PASS=

# Email (use a test/sandbox service)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=test@pricetracker.local
SMTP_FROM_NAME=Price Tracker Test

# LINE (use sandbox/test credentials)
LINE_CHANNEL_ACCESS_TOKEN=test_token
LINE_CHANNEL_SECRET=test_secret

# App settings
APP_ENV=testing
APP_DEBUG=true
